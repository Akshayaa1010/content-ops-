// .vscode/launch.json — F5 to run both servers from VS Code
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (Person A)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "justMyCode": true
    },
    {
      "name": "Celery Worker (Person A)",
      "type": "python",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "app.pipeline.celery_app",
        "worker",
        "--loglevel=info"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env"
    },
    {
      "name": "Frontend (Person B)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/frontend"
    }
  ]
}